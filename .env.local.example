GROQ_API_KEY=your-groq-api-key

# ── Cohere (RAG embeddings — free tier, 384-dim, no credit card) ──────────────
# Free at: https://dashboard.cohere.com  → API Keys → "New Trial Key"
COHERE_API_KEY=your-cohere-trial-api-key
